    "source": "github"
  },
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.htmlweb.ru/",
      "headers": [
        {
          "name": "Authorization",
          "description": "Bearer YOUR_API_KEY с https://htmlweb.ru/user/",
